{
  "name": "gta6-countdown-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "node scripts/update-sitemap.mjs && astro check && astro build",
    "check:sources": "node scripts/check-sources.mjs",
    "deploy:cloudflare": "wrangler pages deploy dist --project-name gta6-countdown-tracker",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "test": "node --test scripts/*.test.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "serve:dist": "node scripts/serve-static.mjs"
  },
  "dependencies": {
    "@astrojs/check": "0.9.2",
    "autoprefixer": "^10.4.23",
    "astro": "^6.3.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {}
}
