{
  "name": "gta6-countdown-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro check && astro build",
    "check:sources": "node scripts/check-sources.mjs",
    "deploy:cloudflare": "wrangler pages deploy dist --project-name gta6-countdown-tracker",
    "test": "node --test scripts/*.test.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "serve:dist": "node scripts/serve-static.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^4.16.18",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "wrangler": "^4.18.0"
  },
  "devDependencies": {}
}
