---
import faqs from '../data/faqs.json';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
const items = limit ? faqs.slice(0, limit) : faqs;
---

<section class="surface rounded-lg p-6">
  <div class="mb-5">
    <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-mint">FAQ</p>
    <h2 class="mt-2 font-display text-3xl font-black text-white">Common GTA 6 tracker questions</h2>
  </div>
  <div class="divide-y divide-white/10">
    {items.map((item) => (
      <details class="group py-4">
        <summary class="cursor-pointer list-none font-display text-lg font-bold text-white">
          <span class="mr-3 text-mint group-open:text-coral">+</span>{item.question}
        </summary>
        <p class="mt-3 max-w-3xl text-zinc-300">{item.answer}</p>
      </details>
    ))}
  </div>
</section>
