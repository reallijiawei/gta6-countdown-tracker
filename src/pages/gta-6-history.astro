---
import FAQSection from '../components/FAQSection.astro';
import HistoryCharts from '../components/HistoryCharts.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { breadcrumbSchema, faqItems, faqSchema, videoGameSchema } from '../lib/seo';

const title = 'GTA Release Timeline: From GTA III to GTA VI';
const description = 'Explore the GTA release timeline, the gap between GTA V and GTA VI, historical platforms, scores and key series data visualizations.';
const schema = [
  breadcrumbSchema([
    { name: 'Home', pathname: '/' },
    { name: 'History', pathname: '/gta-6-history' },
  ]),
  videoGameSchema(),
  faqSchema(faqItems(4)),
];
---

<MainLayout title={title} description={description} pathname="/gta-6-history" schema={schema}>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
    <p class="font-display text-xs font-black uppercase tracking-[0.22em] text-cyan">Series data</p>
    <h1 class="mt-4 max-w-4xl font-display text-5xl font-black leading-tight text-white">GTA release timeline from GTA III to GTA VI.</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-zinc-300">
      The history page gives the site evergreen value beyond day-to-day rumors: release dates, initial platforms, review scores and the unusually long GTA V to GTA VI wait.
    </p>
  </section>

  <section class="mx-auto max-w-7xl space-y-8 px-4 pb-14 sm:px-6">
    <HistoryCharts />
    <div class="surface rounded-lg p-6">
      <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-cyan">Timeline context</p>
      <div class="mt-5 grid gap-6 lg:grid-cols-2">
        <article>
          <h2 class="font-display text-2xl font-black text-white">Why the GTA V to GTA VI gap matters</h2>
          <p class="mt-3 text-zinc-300">
            The long gap changes how people search for GTA 6. Some users want launch facts, while others want context: how unusual the wait is, how platform generations changed and why official details matter more than recycled rumors.
          </p>
        </article>
        <article>
          <h2 class="font-display text-2xl font-black text-white">How history helps this tracker stay useful</h2>
          <p class="mt-3 text-zinc-300">
            Historical launch data gives the site evergreen value after a daily news cycle ends. It also helps separate durable series context from short-lived speculation about price, editions and platform timing.
          </p>
        </article>
      </div>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      <article class="surface rounded-lg p-6">
        <h2 class="font-display text-xl font-black text-white">Release gaps</h2>
        <p class="mt-3 text-zinc-300">Comparing release gaps shows how different the GTA 6 wait feels from earlier mainline entries.</p>
      </article>
      <article class="surface rounded-lg p-6">
        <h2 class="font-display text-xl font-black text-white">Platform shifts</h2>
        <p class="mt-3 text-zinc-300">The series moved across console generations, PC windows and digital storefront expectations.</p>
      </article>
      <article class="surface rounded-lg p-6">
        <h2 class="font-display text-xl font-black text-white">Search intent</h2>
        <p class="mt-3 text-zinc-300">History content supports users who want context rather than only a countdown number.</p>
      </article>
    </div>
    <FAQSection limit={4} />
  </section>
</MainLayout>
