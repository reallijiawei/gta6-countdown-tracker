---
import CountdownTimer from '../components/CountdownTimer.astro';
import FAQSection from '../components/FAQSection.astro';
import PollWidget from '../components/PollWidget.astro';
import PreorderTable from '../components/PreorderTable.astro';
import PriceTable from '../components/PriceTable.astro';
import SourceFreshness from '../components/SourceFreshness.astro';
import StatusCards from '../components/StatusCards.astro';
import UpdateTimeline from '../components/UpdateTimeline.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { breadcrumbSchema, faqItems, faqSchema, videoGameSchema } from '../lib/seo';

const title = 'GTA 6 Countdown: Release Date, Price and Pre-order Tracker';
const description = 'See the GTA 6 countdown, official November 19, 2026 release date, price status, pre-order availability and confirmed PS5/Xbox platforms.';
const schema = [
  breadcrumbSchema([
    { name: 'Home', pathname: '/' },
  ]),
  videoGameSchema(),
  faqSchema(faqItems()),
];
---

<MainLayout title={title} description={description} pathname="/" schema={schema}>
  <section class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1.08fr_0.92fr] lg:py-16">
    <div class="flex flex-col justify-center">
      <p class="font-display text-xs font-black uppercase tracking-[0.22em] text-mint">Unofficial fan-made tracker</p>
      <h1 class="mt-4 font-display text-5xl font-black leading-none text-white sm:text-7xl">
        GTA 6 countdown, price and pre-order status.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-300">
        A compact data hub for the most searched GTA 6 launch questions: when it releases, whether the price is official, which stores have pre-orders, and what platforms are confirmed.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded-full bg-mint px-5 py-3 font-bold text-black transition hover:bg-white" href="/gta-6-countdown">View countdown</a>
        <a class="rounded-full border border-white/15 px-5 py-3 font-bold text-white transition hover:border-mint hover:text-mint" href="/gta-6-price">Check price status</a>
        <a class="rounded-full border border-white/15 px-5 py-3 font-bold text-white transition hover:border-cyan hover:text-cyan" href="/gta-6-release-date">Release date details</a>
      </div>
    </div>
    <div class="surface relative min-h-[440px] overflow-hidden rounded-lg p-6">
      <div class="absolute inset-0 bg-[linear-gradient(130deg,rgba(63,245,163,0.18),transparent_36%),linear-gradient(310deg,rgba(255,107,94,0.16),transparent_42%)]"></div>
      <div class="relative">
        <p class="font-display text-sm font-black uppercase tracking-[0.18em] text-cyan">Launch board</p>
        <div class="mt-8 grid grid-cols-2 gap-3">
          <div class="rounded-md border border-white/10 bg-black/30 p-4">
            <p class="text-sm text-zinc-400">Official date</p>
            <p class="mt-3 font-display text-3xl font-black text-white">Nov 19</p>
            <p class="text-mint">2026</p>
          </div>
          <div class="rounded-md border border-white/10 bg-black/30 p-4">
            <p class="text-sm text-zinc-400">Price</p>
            <p class="mt-3 font-display text-3xl font-black text-amber">TBA</p>
            <p class="text-zinc-400">not official</p>
          </div>
          <div class="rounded-md border border-white/10 bg-black/30 p-4">
            <p class="text-sm text-zinc-400">Pre-order</p>
            <p class="mt-3 font-display text-3xl font-black text-amber">No</p>
            <p class="text-zinc-400">wishlist only</p>
          </div>
          <div class="rounded-md border border-white/10 bg-black/30 p-4">
            <p class="text-sm text-zinc-400">Platforms</p>
            <p class="mt-3 font-display text-3xl font-black text-white">2</p>
            <p class="text-zinc-400">PS5 / Xbox</p>
          </div>
        </div>
        <div class="mt-8 rounded-md border border-white/10 bg-black/25 p-4">
          <div class="mb-3 flex justify-between text-xs font-bold uppercase tracking-[0.14em] text-zinc-400">
            <span>Verified signal</span><span>Rockstar page</span>
          </div>
          <div class="h-2 rounded-full bg-white/10"><div class="h-full w-[78%] rounded-full bg-gradient-to-r from-mint to-cyan"></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl space-y-6 px-4 pb-14 sm:px-6">
    <StatusCards />
    <CountdownTimer />
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-14 sm:px-6">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-cyan">How to use this tracker</p>
        <h2 class="mt-3 font-display text-4xl font-black leading-tight text-white">A quick read on what is confirmed, what is pending and what should be ignored.</h2>
        <p class="mt-5 text-lg leading-8 text-zinc-300">
          GTA 6 search results often mix official details with retailer placeholders, rumor pricing and old platform assumptions. This tracker is built around a simpler rule: keep the public status conservative until an official Rockstar page or platform store page changes.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <article class="surface rounded-lg p-6">
          <h3 class="font-display text-xl font-black text-white">Confirmed launch signal</h3>
          <p class="mt-3 text-zinc-300">The release date, PlayStation 5 and Xbox Series X|S status are treated as confirmed because they appear in official launch messaging.</p>
        </article>
        <article class="surface rounded-lg p-6">
          <h3 class="font-display text-xl font-black text-white">Unconfirmed commercial signal</h3>
          <p class="mt-3 text-zinc-300">Price, editions and pre-order availability remain pending until official stores publish buyable product details.</p>
        </article>
        <article class="surface rounded-lg p-6">
          <h3 class="font-display text-xl font-black text-white">Rumor filter</h3>
          <p class="mt-3 text-zinc-300">Forum posts, screenshots without source links, retail leaks and placeholder SKUs are not promoted into the main status cards.</p>
        </article>
        <article class="surface rounded-lg p-6">
          <h3 class="font-display text-xl font-black text-white">Daily freshness</h3>
          <p class="mt-3 text-zinc-300">The source checker records whether tracked official pages were reachable and whether expected public signals remained present.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-7xl gap-6 px-4 pb-14 sm:px-6 lg:grid-cols-2">
    <div>
      <div class="mb-4">
        <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-mint">Price tracker</p>
        <h2 class="font-display text-3xl font-black text-white">Official price has not been announced.</h2>
      </div>
      <PriceTable />
    </div>
    <div>
      <div class="mb-4">
        <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-cyan">Pre-order tracker</p>
        <h2 class="font-display text-3xl font-black text-white">Pre-orders are not officially live.</h2>
      </div>
      <PreorderTable />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-14 sm:px-6">
    <div class="surface rounded-lg p-6">
      <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-cyan">Popular checks</p>
      <h2 class="mt-2 font-display text-3xl font-black text-white">Jump to the GTA 6 answer you need.</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <a class="rounded-md border border-white/10 bg-black/25 p-4 transition hover:border-mint" href="/gta-6-release-date">
          <span class="font-display text-lg font-black text-white">Release date</span>
          <span class="mt-2 block text-sm text-zinc-400">Official date, delay status and unlock caveats.</span>
        </a>
        <a class="rounded-md border border-white/10 bg-black/25 p-4 transition hover:border-mint" href="/gta-6-platforms">
          <span class="font-display text-lg font-black text-white">Platforms</span>
          <span class="mt-2 block text-sm text-zinc-400">PS5, Xbox Series X|S and PC status.</span>
        </a>
        <a class="rounded-md border border-white/10 bg-black/25 p-4 transition hover:border-mint" href="/gta-6-preorder">
          <span class="font-display text-lg font-black text-white">Pre-order</span>
          <span class="mt-2 block text-sm text-zinc-400">Wishlist versus live pre-order signals.</span>
        </a>
        <a class="rounded-md border border-white/10 bg-black/25 p-4 transition hover:border-mint" href="/gta-6-history">
          <span class="font-display text-lg font-black text-white">GTA history</span>
          <span class="mt-2 block text-sm text-zinc-400">Release timeline and series context.</span>
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-14 sm:px-6">
    <div class="surface rounded-lg p-6">
      <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-amber">Current launch snapshot</p>
      <div class="mt-5 grid gap-6 lg:grid-cols-3">
        <div>
          <h2 class="font-display text-2xl font-black text-white">What is solid today</h2>
          <p class="mt-3 text-zinc-300">The tracker centers on November 19, 2026, with PS5 and Xbox Series X|S listed as the current launch platforms.</p>
        </div>
        <div>
          <h2 class="font-display text-2xl font-black text-white">What can still change</h2>
          <p class="mt-3 text-zinc-300">Regional release timing, digital edition names, pre-load timing, store pages and price tiers can change before launch.</p>
        </div>
        <div>
          <h2 class="font-display text-2xl font-black text-white">What to watch next</h2>
          <p class="mt-3 text-zinc-300">The most meaningful updates would be official store pricing, a live pre-order button, edition breakdowns or a PC announcement.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl space-y-6 px-4 pb-14 sm:px-6">
    <PollWidget />
    <SourceFreshness />
    <UpdateTimeline />
    <FAQSection />
  </section>
</MainLayout>
