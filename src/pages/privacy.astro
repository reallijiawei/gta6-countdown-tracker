---
import MainLayout from '../layouts/MainLayout.astro';
import { breadcrumbSchema, videoGameSchema } from '../lib/seo';

const title = 'Privacy Policy | GTA 6 Price & Countdown Tracker';
const description = 'Privacy policy for the unofficial GTA 6 Price & Countdown Tracker, including poll storage, browser storage and source freshness checks.';
const schema = [
  breadcrumbSchema([
    { name: 'Home', pathname: '/' },
    { name: 'Privacy', pathname: '/privacy' },
  ]),
  videoGameSchema(),
];
---

<MainLayout title={title} description={description} pathname="/privacy" schema={schema}>
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <p class="font-display text-xs font-black uppercase tracking-[0.22em] text-cyan">Privacy</p>
    <h1 class="mt-4 font-display text-5xl font-black leading-tight text-white">Privacy policy</h1>
    <div class="prose-lite mt-6 space-y-5 text-lg">
      <p>
        This unofficial tracker is designed as a static information site. It does not provide user accounts, account login, newsletter signup or payment processing.
      </p>
      <p>
        Poll buttons store a small browser-local marker in localStorage so the same browser can show that it already voted. The public poll totals are stored in Cloudflare KV as aggregate counts by poll option, not as named user profiles.
      </p>
      <p>
        Cloudflare may process standard request metadata such as IP address, user agent, request path and timestamp to deliver and protect the site. Those platform logs are handled under Cloudflare's own policies and retention controls.
      </p>
      <p>
        Google Analytics is used only after a visitor accepts analytics cookies in the on-site consent banner. If analytics is declined, the site keeps that preference in localStorage and does not load the Google Analytics tag.
      </p>
      <p>
        The site's GTA 6 status information is maintained from official and clearly labeled sources. Daily freshness checks update source metadata, but they do not collect visitor identity information.
      </p>
      <p>
        Privacy contact: <a href="mailto:privacy@launchdaytracker.online">privacy@launchdaytracker.online</a>.
      </p>
      <p>
        This site is fan-made and unaffiliated with Rockstar Games, Take-Two Interactive, PlayStation, Xbox or any retailer.
      </p>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      <article class="surface rounded-lg p-6">
        <h2 class="font-display text-2xl font-black text-white">What is stored</h2>
        <p class="mt-3 text-zinc-300">Aggregate poll option totals, browser-local vote markers, analytics consent preference and normal Cloudflare delivery logs.</p>
      </article>
      <article class="surface rounded-lg p-6">
        <h2 class="font-display text-2xl font-black text-white">What is not stored here</h2>
        <p class="mt-3 text-zinc-300">No site account, password, email signup, payment details, private messages or gameplay account data.</p>
      </article>
    </div>
  </section>
</MainLayout>
