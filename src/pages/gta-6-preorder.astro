---
import FAQSection from '../components/FAQSection.astro';
import PreorderTable from '../components/PreorderTable.astro';
import StatusPill from '../components/StatusPill.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { breadcrumbSchema, faqItems, faqSchema, videoGameSchema } from '../lib/seo';

const title = 'GTA 6 Pre-order Tracker: Is GTA 6 Available to Pre-order?';
const description = 'Check whether GTA 6 pre-orders are live on PlayStation Store, Xbox Store, Amazon, Best Buy and other retailers. Updated unofficial tracker.';
const schema = [
  breadcrumbSchema([
    { name: 'Home', pathname: '/' },
    { name: 'Pre-order', pathname: '/gta-6-preorder' },
  ]),
  videoGameSchema(),
  faqSchema(faqItems(5)),
];
---

<MainLayout title={title} description={description} pathname="/gta-6-preorder" schema={schema}>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
    <p class="font-display text-xs font-black uppercase tracking-[0.22em] text-cyan">Pre-order status</p>
    <h1 class="mt-4 max-w-4xl font-display text-5xl font-black leading-tight text-white">GTA 6 pre-orders are not officially live yet.</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-zinc-300">
      Wishlist pages are useful signals, but they are not live pre-orders. This tracker keeps stores, regions and platform notes separate so placeholder activity is not mistaken for official availability.
    </p>
    <div class="mt-7 flex flex-wrap gap-3">
      <StatusPill status="not_live" />
      <StatusPill status="wishlist" />
      <StatusPill status="placeholder" />
    </div>
  </section>

  <section class="mx-auto max-w-7xl space-y-8 px-4 pb-14 sm:px-6">
    <PreorderTable />
    <div class="surface rounded-lg p-6">
      <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-cyan">Pre-order signal guide</p>
      <div class="mt-5 grid gap-6 lg:grid-cols-3">
        <article>
          <h2 class="font-display text-2xl font-black text-white">Wishlist</h2>
          <p class="mt-3 text-zinc-300">A wishlist page means the platform is collecting interest or preparing a product page. It does not mean money can be paid or an edition can be reserved.</p>
        </article>
        <article>
          <h2 class="font-display text-2xl font-black text-white">Placeholder</h2>
          <p class="mt-3 text-zinc-300">Retail placeholders can appear before official details. They should be monitored, but not treated as live availability unless the page clearly supports checkout.</p>
        </article>
        <article>
          <h2 class="font-display text-2xl font-black text-white">Live pre-order</h2>
          <p class="mt-3 text-zinc-300">A live pre-order should show an official store, confirmed edition, price, supported platform and purchase flow. That is the threshold for changing this page’s status.</p>
        </article>
      </div>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      <article class="surface rounded-lg p-6">
        <h2 class="font-display text-2xl font-black text-white">What to check before buying</h2>
        <p class="mt-3 text-zinc-300">Confirm the region, platform, edition, refund policy and whether the seller is an official platform store or a trusted retailer.</p>
      </article>
      <article class="surface rounded-lg p-6">
        <h2 class="font-display text-2xl font-black text-white">What this tracker avoids</h2>
        <p class="mt-3 text-zinc-300">No gray-market keys, account sales, leaked downloads, fake beta access or unofficial checkout links are included.</p>
      </article>
    </div>
    <div class="surface rounded-lg p-6">
      <h2 class="font-display text-3xl font-black text-white">What will change when pre-orders go live?</h2>
      <div class="mt-5 grid gap-5 md:grid-cols-3">
        <p class="text-zinc-300">The status card should move from not live to live for stores with a confirmed checkout flow.</p>
        <p class="text-zinc-300">The table should add edition names, official prices, regions and direct store links.</p>
        <p class="text-zinc-300">The update timeline should record the source and date so readers can audit the change later.</p>
      </div>
    </div>
    <FAQSection limit={5} />
  </section>
</MainLayout>
